{
  "name": "agent-task-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "atl": "build/server/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "atl": "tsx src/cli.ts",
    "board:dev": "vite",
    "board:server": "tsx src/server/start.ts"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "ulid": "^3.0.1",
    "yaml": "^2.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.28.0"
}
