{
  "name": "agent-task-loop",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "bin": {
    "atl": "build/server/cli.js"
  },
  "scripts": {
    "build": "pnpm build:server && pnpm build:ui && pnpm build:obsidian && pnpm build:runner",
    "build:obsidian": "vite build --config vite.obsidian.config.ts",
    "build:runner": "vite build --config vite.runner.config.ts",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ui": "vite build --outDir build/ui",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "atl": "tsx src/cli.ts",
    "board:dev": "vite",
    "board:server": "tsx src/server/start.ts"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@tanstack/react-query": "^5.101.2",
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "fast-glob": "^3.3.3",
    "fastify": "^5.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ulid": "^3.0.1",
    "yaml": "^2.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "obsidian": "^1.13.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.1.4",
    "vitest": "^3.2.0"
  },
  "packageManager": "pnpm@10.28.0"
}
